local FARM_ISLANDS_ENDGAME_FIRST = {
    "Lawless", "Ninja", "SoulDominion", "Judgement", "Academy",
    "Slime", "Shinjuku", "HollowIsland", "Shibuya", "Snow",
    "Desert", "Jungle",
