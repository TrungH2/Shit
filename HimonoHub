        if not CFG.AutoCombo then comboIdx = 1; task.wait(0.5); continue end
        if _isRespawning or not character or not humanoid or humanoid.Health <= 0 then continue end
        local parsed = ParseCombo(CFG.ComboPattern)
        if #parsed == 0 then continue end
        if comboIdx > #parsed then comboIdx = 1 end
        local action = parsed[comboIdx]
        local waitTime = tonumber(action)
        if waitTime then
            if CFG.ComboMode ~= "Instant" then task.wait(waitTime) end
            comboIdx = comboIdx + 1
        else
            local slot = keyToSlot[action]
            if slot then
                pcall(function() RequestAbility:FireServer(slot) end)
                if CFG.ComboMode ~= "Instant" then task.wait(0.3) end
            end
            comboIdx = comboIdx + 1
        end
        if comboIdx > #parsed then comboIdx = 1; task.wait(0.5) end
    end
end)

