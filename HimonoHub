            fn(unpack(args))
        end)
        if ok then return true end
        -- Retry with exponential backoff
        if attempt < maxRetries then
            task.wait(0.1 * attempt) -- 0.1s, 0.2s, 0.3s
        else
            warn("[HimonoHub] Remote failed after " .. maxRetries .. " retries: " .. tostring(err))
        end
    end
    return false
end

-- Convenience: FireServer with retry
local function safeFireServer(remote, ...)
    local args = {...}
    local maxRetries = 3
    for attempt = 1, maxRetries do
        task.wait(math.random(10, 40) / 1000)
        local ok, err = pcall(function()
            remote:FireServer(unpack(args))
        end)
        if ok then return true end
        if attempt < maxRetries then
            task.wait(0.1 * attempt)
        end
    end
    return false
end

-- Convenience: InvokeServer with retry + timeout protection
local function safeInvokeServer(remote, ...)
    local args = {...}
    local maxRetries = 2
    local result = nil
    for attempt = 1, maxRetries do
        task.wait(math.random(10, 40) / 1000)
        local ok, res = pcall(function()
            return remote:InvokeServer(unpack(args))
        end)
        if ok then return true, res end
        if attempt < maxRetries then
            task.wait(0.2 * attempt)
        end
    end
    return false, nil
end

-- Throttle tracker to prevent remote spam
local _lastCallTime = {}
local function throttle(key, minInterval)
    local now = tick()
    if _lastCallTime[key] and (now - _lastCallTime[key]) < minInterval then
        return false
    end
    _lastCallTime[key] = now
    return true
end

