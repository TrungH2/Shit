-- ============ ANTI-CHEAT HELPERS ============
local function safeWait(baseTime, variance)
    variance = variance or 0.3
    local jitter = baseTime * variance * (math.random() * 2 - 1)
    local final = math.max(0.02, baseTime + jitter)
    task.wait(final)
    return final
end

local function safeCall(fn, ...)
    local args = {...}
    local ok, err = pcall(function() fn(unpack(args)) end)
    if not ok then warn("[HimonoHub] " .. tostring(err)) end
    return ok
end

local function safeFireServer(remote, ...)
    local args = {...}
    local ok, err = pcall(function() remote:FireServer(unpack(args)) end)
    return ok
end

local _lastCallTime = {}
local function throttle(key, minInterval)
    local now = tick()
    if _lastCallTime[key] and (now - _lastCallTime[key]) < minInterval then return false end
    _lastCallTime[key] = now
    return true
end

