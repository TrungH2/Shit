-- Lấy level từ mob (từ name, attribute, hoặc UI)
local function getMobLevel(mob)
    if not mob then return 0 end
    local lvl = 0
    pcall(function()
        -- Check Attribute
        if mob:GetAttribute("Level") then
            lvl = tonumber(mob:GetAttribute("Level")) or 0
            return
        end
        -- Check IntValue/NumberValue tên "Level"
        local lvlVal = mob:FindFirstChild("Level")
        if lvlVal and (lvlVal:IsA("IntValue") or lvlVal:IsA("NumberValue")) then
            lvl = lvlVal.Value or 0
            return
        end
        -- Parse từ tên mob: "Mob Name [Lv. 50]" hoặc "Mob Lv50"
        local name = mob.Name
        local parsed = tonumber(string.match(name, "Lv%.?%s*(%d+)"))
            or tonumber(string.match(name, "Level%s*(%d+)"))
            or tonumber(string.match(name, "%[(%d+)%]"))
        if parsed then lvl = parsed end
        -- Check BillboardGui text trên đầu mob
        if lvl == 0 then
            for _, gui in ipairs(mob:GetDescendants()) do
                if gui:IsA("TextLabel") then
                    local num = tonumber(string.match(gui.Text, "Lv%.?%s*(%d+)"))
                        or tonumber(string.match(gui.Text, "Level%s*(%d+)"))
                    if num then lvl = num; break end
                end
            end
        end
    end)
    return lvl
end

-- Lấy player level (deep search cho Sailor Piece)
local function getPlayerLevel()
    local lvl = 1
    pcall(function()
        -- 1. leaderstats (phổ biến nhất)
        local ls = Plr:FindFirstChild("leaderstats")
        if ls then
            local v = ls:FindFirstChild("Level") or ls:FindFirstChild("Lv")
            if v and v.Value and tonumber(v.Value) and tonumber(v.Value) > 0 then
                lvl = tonumber(v.Value)
                return
            end
        end
        -- 2. PlayerData / Data (nested paths)
        for _, containerName in ipairs({"PlayerData", "Data", "Stats", "PlayerStats", "SaveData"}) do
            local container = Plr:FindFirstChild(containerName)
            if container then
                -- Direct child
                local v = container:FindFirstChild("Level") or container:FindFirstChild("Lv")
                if v and v.Value and tonumber(v.Value) and tonumber(v.Value) > 0 then
                    lvl = tonumber(v.Value)
                    return
                end
                -- Deep search trong container
                for _, desc in ipairs(container:GetDescendants()) do
                    if (desc:IsA("IntValue") or desc:IsA("NumberValue") or desc:IsA("StringValue")) then
                        if desc.Name == "Level" or desc.Name == "Lv" or desc.Name == "PlayerLevel" then
                            local val = tonumber(desc.Value)
                            if val and val > 0 then
                                lvl = val
                                return
                            end
                        end
                    end
                end
            end
        end
        -- 3. Attribute trên player
        local attrLvl = Plr:GetAttribute("Level") or Plr:GetAttribute("Lv") or Plr:GetAttribute("PlayerLevel")
        if attrLvl and tonumber(attrLvl) and tonumber(attrLvl) > 0 then
            lvl = tonumber(attrLvl)
            return
        end
        local _char = Plr.Character
        if _char then
            local charAttr = _char:GetAttribute("Level") or _char:GetAttribute("Lv")
            if charAttr and tonumber(charAttr) and tonumber(charAttr) > 0 then
                lvl = tonumber(charAttr)
                return
            end
        end
        -- 5. Deep search toàn bộ player descendants
        for _, desc in ipairs(Plr:GetDescendants()) do
            if (desc:IsA("IntValue") or desc:IsA("NumberValue")) and 
               (desc.Name == "Level" or desc.Name == "Lv") then
                local val = tonumber(desc.Value)
                if val and val > 0 then
                    lvl = val
                    return
                end
            end
        end
        -- 6. Fallback: Parse từ GUI (tìm text chứa "Lv" hoặc "Level")
        pcall(function()
            for _, gui in ipairs(Plr.PlayerGui:GetDescendants()) do
                if gui:IsA("TextLabel") and gui.Visible then
                    local txt = gui.Text
                    local num = tonumber(string.match(txt, "Lv%.?%s*(%d+)"))
                        or tonumber(string.match(txt, "Level%s*(%d+)"))
                    if num and num > 0 and num < 99999 then
                        lvl = num
                        return
                    end
                end
            end
        end)
    end)
    return lvl
end

-- Tìm mob phù hợp level
local function findMobForLevel(maxRange)
    maxRange = maxRange or CFG.FarmRange
    local best, bestDist = nil, math.huge
    local playerLvl = getPlayerLevel()
    
    -- Ưu tiên tìm trong Mobs folder
    local folders = {}
    for _, name in ipairs({"Mobs", "NPCs", "Enemies", "Monsters"}) do
        local f = workspace:FindFirstChild(name)
        if f then table.insert(folders, f) end
    end
    
    local function scanFolder(folder)
        for _, obj in ipairs(folder:GetChildren()) do
            if obj:IsA("Model") and obj ~= Plr.Character then
                local hum  = obj:FindFirstChildOfClass("Humanoid")
                local root = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Root")
                local myRoot = GetCharacter() and GetCharacter():FindFirstChild("HumanoidRootPart")
                if hum and hum.Health > 0 and root and myRoot then
                    local d = (myRoot.Position - root.Position).Magnitude
                    if d < maxRange and d < bestDist then
                        bestDist = d
                        best = obj
                    end
                end
            end
        end
    end
    
    -- Scan mob folders trước
    for _, folder in ipairs(folders) do
        scanFolder(folder)
    end
    
    -- Fallback: dùng workspace descendants
    if not best then
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("Model") and obj ~= Plr.Character then
                local hum  = obj:FindFirstChildOfClass("Humanoid")
                local root = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Root")
                local myRoot = GetCharacter() and GetCharacter():FindFirstChild("HumanoidRootPart")
                if hum and hum.Health > 0 and root and myRoot then
                    -- Bỏ qua NPC/player
                    local isPlayer = false
                    for _, p in ipairs(Players:GetPlayers()) do
                        if p.Character == obj then isPlayer = true; break end
                    end
                    if not isPlayer then
                        local d = (myRoot.Position - root.Position).Magnitude
                        if d < maxRange and d < bestDist then
                            bestDist = d
                            best = obj
                        end
                    end
                end
            end
        end
    end
    
    return best, bestDist
end

-- Tìm Quest NPC gần nhất
local function findQuestNPC()
    local best, bestDist = nil, math.huge
    pcall(function()
        -- Tìm NPC có chữ "Quest" trong tên hoặc billboardgui
        local npcFolders = {}
        for _, name in ipairs({"NPCs", "QuestNPCs", "Quest", "Interactables"}) do
            local f = workspace:FindFirstChild(name)
            if f then table.insert(npcFolders, f) end
        end
        
        local function checkNPC(obj)
            if obj == Plr.Character then return end
            
            local root = nil
            if obj:IsA("Model") then
                root = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Root") or obj.PrimaryPart
            elseif obj:IsA("BasePart") then
                root = obj
            end
            
            local myRoot = GetCharacter() and GetCharacter():FindFirstChild("HumanoidRootPart")
            if not root or not myRoot then return end
            
            -- Check xem có phải Quest NPC không
            local isQuestNPC = false
            local name_lower = obj.Name:lower()
            if name_lower:find("quest") or name_lower:find("npc") then
                isQuestNPC = true
            end
            -- Check billboard text
            if not isQuestNPC then
                for _, gui in ipairs(obj:GetDescendants()) do
                    if gui:IsA("TextLabel") or gui:IsA("TextButton") then
                        local txt = gui.Text:lower()
                        if txt:find("quest") or txt:find("!") or txt:find("nhiệm vụ") then
                            isQuestNPC = true
                            break
                        end
                    end
                end
            end
            -- Check ProximityPrompt
            if not isQuestNPC then
                for _, pp in ipairs(obj:GetDescendants()) do
                    if pp:IsA("ProximityPrompt") then
                        local act = pp.ActionText:lower()
                        local objt = pp.ObjectText:lower()
                        if act:find("quest") or act:find("talk") or objt:find("quest") then
                            isQuestNPC = true
                            break
                        end
                    end
                end
            end
            
            if isQuestNPC then
                local d = (myRoot.Position - root.Position).Magnitude
                if d < bestDist then
                    bestDist = d
                    best = obj
                end
            end
        end
        
        for _, folder in ipairs(npcFolders) do
            for _, obj in ipairs(folder:GetDescendants()) do
                checkNPC(obj)
            end
        end
        -- Fallback
        if not best then
            for _, obj in ipairs(workspace:GetDescendants()) do
                checkNPC(obj)
            end
        end
    end)
    return best, bestDist
end

-- Di chuyển tới vị trí target
local function moveToTarget(targetRoot)
    local myRoot = GetCharacter() and GetCharacter():FindFirstChild("HumanoidRootPart")
    if not targetRoot or not myRoot then return end
    local p = targetRoot.Position
    local d = CFG.Distance
    local targetPos
    if     CFG.Position == "Above"  then targetPos = p + Vector3.new(0, d, 0)
    elseif CFG.Position == "Below"  then targetPos = p + Vector3.new(0, -d, 0)
    elseif CFG.Position == "Front"  then targetPos = p + targetRoot.CFrame.LookVector * d
    elseif CFG.Position == "Behind" then targetPos = p - targetRoot.CFrame.LookVector * d
    else                                 targetPos = p + Vector3.new(d, 0, 0)
    end
    if CFG.BypassTp then
        pcall(function() myRoot.CFrame = CFrame.new(targetPos) end)
    else
        local info = TweenInfo.new(CFG.TweenSpeed / 1000, Enum.EasingStyle.Linear)
        local t = TweenSvc:Create(myRoot, info, {CFrame = CFrame.new(targetPos)})
        t:Play(); t.Completed:Wait()
    end
end

