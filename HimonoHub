-- ───── Auto Farm Quest (Liên tục: farm mob + tự nhận quest mới khi xong) ─────
task.spawn(function()
    local _lastQuestAccept = 0
    local _lastIslandTp = 0
    local _questInitialized = false
    
    while true do
        task.wait(0.1)
        if not CFG.AutoFarmQuest then
            _questInitialized = false -- Reset khi tắt rồi bật lại
            continue
        end
        if not GetCharacter() then continue end
        
        -- Xác định quest NPC và island
        local questNPC, questIsland
        if CFG.SelectedQuestNPC == "Auto" or not CFG.SelectedQuestNPC then
            local playerLvl = getPlayerLevel()
            questNPC, questIsland = getQuestNPCForLevel(playerLvl)
        else
            questNPC = CFG.SelectedQuestNPC
            questIsland = CFG.SelectedQuestIsland
        end
        
        -- Lần đầu tiên: abandon quest cũ + nhận quest mới + tele đến đảo
        if not _questInitialized then
            _questInitialized = true
            -- Tele đến đảo
            if questIsland then
                pcall(function() Remotes.TP_Portal:FireServer(questIsland) end)
                safeWait(2, 0.2)
            end
            -- Abandon quest cũ 1 lần duy nhất
            pcall(function() Remotes.QuestAbandon:FireServer("repeatable") end)
            task.wait(0.2)
            -- Nhận quest mới
            pcall(function() Remotes.QuestAccept:FireServer(questNPC) end)
            _lastQuestAccept = tick()
            _lastIslandTp = tick()
        end
        
        -- Mỗi 10s: check lại island (phòng bị đẩy ra)
        local now = tick()
        if questIsland and now - _lastIslandTp > 10 then
            _lastIslandTp = now
            pcall(function() Remotes.TP_Portal:FireServer(questIsland) end)
            safeWait(1.5, 0.2)
        end
        
        -- Mỗi 3s: thử nhận quest (không abandon!)
        -- Nếu quest chưa xong → QuestAccept không ảnh hưởng gì
        -- Nếu quest đã xong → QuestAccept sẽ nhận quest mới ngay!
        if now - _lastQuestAccept > 3 then
            _lastQuestAccept = now
            pcall(function() Remotes.QuestAccept:FireServer(questNPC) end)
        end
        
        -- Auto equip weapon
        if CFG.AutoEquip and CFG.SelectedWeapon ~= "--" then
            equipWeapon(CFG.SelectedWeapon)
        end
        
        -- Tìm mob gần nhất → teleport tới (attack/skill do loop riêng lo)
        local mob = findMobForLevel(CFG.FarmRange)
        if mob then
            local root = mob:FindFirstChild("HumanoidRootPart") or mob:FindFirstChild("Root")
            if root then
                moveToTarget(root)
            end
        end
    end
end)

