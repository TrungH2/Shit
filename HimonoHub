                if string.find(txt, "wave") or string.find(txt, "floor") then
                    local num = string.match(txt, "wave%s*(%d+)")
                        or string.match(txt, "floor%s*(%d+)")
                        or string.match(txt, "%d+")
                    if num then
                        waveNum = tonumber(num)
                        return
                    end
                end
            end
        end
    end)
    return waveNum
end

