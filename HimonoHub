-- =====================================================
--     TITLE / RUNE / BUILD AUTO-SWITCH (from Source)
-- =====================================================
task.spawn(function()
    while true do
        safeWait(2, 0.3)
        local nearBoss = false
        local bossHP = 100
        for _, v in ipairs(PATH.Mobs:GetChildren()) do
            if v:IsA("Model") and v.Name:lower():find("boss") then
                local hum = v:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health > 0 then
                    nearBoss = true
                    bossHP = (hum.Health / hum.MaxHealth) * 100
                    break
                end
            end
        end
        local farmType = nearBoss and "Boss" or "None"
        if CFG.AutoTitle then
            local toEquip = CFG.DefaultTitle or "None"
            if farmType == "Boss" then toEquip = CFG.Title_Boss or toEquip end
            if toEquip and toEquip ~= "None" and toEquip ~= "" then
                if toEquip:find("Best ") then
                    local statMap = {["Best EXP"]="XPPercent",["Best Money"]="MoneyPercent",["Best Luck"]="LuckPercent",["Best DMG"]="DamagePercent"}
                    local tStat = statMap[toEquip]
                    if tStat and #Tables.UnlockedTitle > 0 then
                        local bestId, bestVal = nil, -1
                        for _, tid in ipairs(Tables.UnlockedTitle) do
                            local td = Modules.Title.Titles and Modules.Title.Titles[tid]
                            if td and td.statBonuses and td.statBonuses[tStat] and td.statBonuses[tStat] > bestVal then
                                bestVal = td.statBonuses[tStat]; bestId = tid
                            end
                        end
                        if bestId then toEquip = bestId end
                    end
                end
                if toEquip ~= Shared.LastSwitch.Title then
                    pcall(function() Remotes.EquipTitle:FireServer(toEquip) end)
                    Shared.LastSwitch.Title = toEquip
                end
            end
        end
        if CFG.AutoRune then
            local toEquip = CFG.DefaultRune or "None"
            if farmType == "Boss" then toEquip = CFG.Rune_Boss or toEquip end
            if toEquip and toEquip ~= "None" and toEquip ~= "" and toEquip ~= Shared.LastSwitch.Rune then
                pcall(function() Remotes.EquipRune:FireServer("Equip", toEquip) end)
                Shared.LastSwitch.Rune = toEquip
            end
        end
        if CFG.AutoBuild and tick() - Shared.LastBuildSwitch > 3.1 then
            local toEquip = CFG.DefaultBuild or "None"
            if farmType == "Boss" then toEquip = CFG.Build_Boss or toEquip end
            if toEquip and toEquip ~= "None" and toEquip ~= "" then
                local loadNum = tonumber(toEquip)
                if loadNum then
                    pcall(function() Remotes.LoadoutLoad:FireServer(loadNum) end)
                    Shared.LastBuildSwitch = tick()
                end
            end
        end
    end
end)

