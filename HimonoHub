-- ───── Auto Farm Level (Smart Island + Tìm mob → di chuyển) ─────
local _lastIslandCheck = 0
local _lastIslandTeleported = nil
task.spawn(function()
    while task.wait(0.1) do
        if CFG.AutoFarmLevel and not CFG._isFarmingWorldBoss and not _isRespawning and character and humanoid and humanoid.Health > 0 and rootPart then
            -- SKIP island teleport nếu đang trong dungeon/tower
            if not CFG._isInDungeon then
                -- Auto equip weapon trước khi farm
                if CFG.AutoEquip and CFG.SelectedWeapon ~= "--" then
                    equipWeapon(CFG.SelectedWeapon)
                end
                
                -- Smart Island: Check level mỗi 15 giây → teleport đúng island
                if CFG.SmartIslandFarm then
                    local now = tick()
                    if now - _lastIslandCheck > 15 then
                        _lastIslandCheck = now
                        local playerLvl = getPlayerLevel()
                        local targetIsland = getIslandForLevel(playerLvl)
                        
                        if targetIsland ~= _lastIslandTeleported then
                            _lastIslandTeleported = targetIsland
                            CFG._currentFarmIsland = targetIsland
                            
                            Rayfield:Notify({
                                Title = "Smart Farm",
                                Content = "Level " .. playerLvl .. " → Teleport đến " .. targetIsland,
                                Duration = 4,
                            })
                            
                            pcall(function() TeleportPortal:FireServer(targetIsland) end)
                            safeWait(3, 0.2)
                        end
                    end
                end
                
                -- Tìm mob gần nhất
                local nearest = findMobForLevel(CFG.FarmRange)
                
                -- Nếu không tìm thấy mob → re-teleport
                if not nearest and CFG.SmartIslandFarm then
                    local playerLvl = getPlayerLevel()
                    local targetIsland = getIslandForLevel(playerLvl)
                    pcall(function() TeleportPortal:FireServer(targetIsland) end)
                    safeWait(3, 0.2)
                    nearest = findMobForLevel(CFG.FarmRange)
                end
                
                -- Teleport tới mob (attack/skill do loop riêng lo)
                if nearest then
                    local root = nearest:FindFirstChild("HumanoidRootPart") or nearest:FindFirstChild("Root")
                    if root then
                        moveToTarget(root)
                    end
                end
            else
                -- Đang trong dungeon → chỉ farm mob tại chỗ
                local nearest = findMobForLevel(CFG.FarmRange)
                if nearest then
                    local root = nearest:FindFirstChild("HumanoidRootPart") or nearest:FindFirstChild("Root")
                    if root then
                        moveToTarget(root)
                    end
                end
            end
            
            -- Update status
            pcall(function()
                local lvl = getPlayerLevel()
                local island = CFG._currentFarmIsland or "N/A"
                local dungeonStr = CFG._isInDungeon and " [IN DUNGEON]" or ""
                local wbStr = CFG._isFarmingWorldBoss and " [WORLD BOSS RUSH]" or ""
                statusLabel:Set("Level: " .. lvl .. " | Island: " .. island .. dungeonStr .. wbStr)
            end)
        end
    end
end)

-- ───── Auto Farm Quest (Liên tục: farm mob + tự nhận quest mới khi xong) ─────
task.spawn(function()
    local _lastQuestAccept = 0
    local _lastIslandTp = 0
    local _questInitialized = false
    
    while true do
        task.wait(0.1)
        if not CFG.AutoFarmQuest then
            _questInitialized = false -- Reset khi tắt rồi bật lại
            continue
        end
        if not character or not humanoid or humanoid.Health <= 0 or _isRespawning then continue end
        
        -- Xác định quest NPC và island
        local questNPC, questIsland
        if CFG.SelectedQuestNPC == "Auto" or not CFG.SelectedQuestNPC then
            local playerLvl = getPlayerLevel()
            questNPC, questIsland = getQuestNPCForLevel(playerLvl)
        else
            questNPC = CFG.SelectedQuestNPC
            questIsland = CFG.SelectedQuestIsland
        end
        
        -- Lần đầu tiên: abandon quest cũ + nhận quest mới + tele đến đảo
        if not _questInitialized then
            _questInitialized = true
            -- Tele đến đảo
            if questIsland then
                pcall(function() TeleportPortal:FireServer(questIsland) end)
                safeWait(2, 0.2)
            end
            -- Abandon quest cũ 1 lần duy nhất
            pcall(function() QuestAbandon:FireServer("repeatable") end)
            task.wait(0.2)
            -- Nhận quest mới
            pcall(function() QuestAccept:FireServer(questNPC) end)
            _lastQuestAccept = tick()
            _lastIslandTp = tick()
        end
        
        -- Mỗi 10s: check lại island (phòng bị đẩy ra)
        local now = tick()
        if questIsland and now - _lastIslandTp > 10 then
            _lastIslandTp = now
            pcall(function() TeleportPortal:FireServer(questIsland) end)
            safeWait(1.5, 0.2)
        end
        
        -- Mỗi 3s: thử nhận quest (không abandon!)
        -- Nếu quest chưa xong → QuestAccept không ảnh hưởng gì
        -- Nếu quest đã xong → QuestAccept sẽ nhận quest mới ngay!
        if now - _lastQuestAccept > 3 then
            _lastQuestAccept = now
            pcall(function() QuestAccept:FireServer(questNPC) end)
        end
        
        -- Auto equip weapon
        if CFG.AutoEquip and CFG.SelectedWeapon ~= "--" then
            equipWeapon(CFG.SelectedWeapon)
        end
        
        -- Tìm mob gần nhất → teleport tới (attack/skill do loop riêng lo)
        local mob = findMobForLevel(CFG.FarmRange)
        if mob then
            local root = mob:FindFirstChild("HumanoidRootPart") or mob:FindFirstChild("Root")
            if root then
                moveToTarget(root)
            end
        end
    end
end)

