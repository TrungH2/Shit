-- ───── Auto Skill ─────
task.spawn(function()
    while true do
        local baseDelay = CFG.SkillDelay
        if CFG.AntiDetection then
            baseDelay = baseDelay + math.random(10, 60) / 1000 -- +10~60ms jitter
        end
        task.wait(baseDelay)

        if CFG.AutoSkill and not _isRespawning and character and humanoid and humanoid.Health > 0 then
            -- Tìm mob gần nhất (cached, efficient)
            local mob = nil
            local nearDist = math.huge

            -- Chỉ tìm trong Mobs folder nếu có, fallback workspace
            local mobFolder = workspace:FindFirstChild("Mobs") or workspace:FindFirstChild("NPCs") or workspace
            for _, obj in ipairs(mobFolder:GetChildren()) do
                if obj:IsA("Model") and obj ~= character then
                    local hum  = obj:FindFirstChildOfClass("Humanoid")
                    local root = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Root")
                    if hum and hum.Health > 0 and root and rootPart then
                        local d = (rootPart.Position - root.Position).Magnitude
                        if d < nearDist then nearDist = d; mob = obj end
                    end
                end
            end

            -- Fallback: scan descendants nếu folder không tìm thấy
            if not mob then
                for _, obj in ipairs(workspace:GetDescendants()) do
                    if obj:IsA("Model") and obj ~= character then
                        local hum  = obj:FindFirstChildOfClass("Humanoid")
                        local root = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Root")
                        if hum and hum.Health > 0 and root and rootPart then
                            local d = (rootPart.Position - root.Position).Magnitude
                            if d < nearDist and d < 200 then nearDist = d; mob = obj end
                        end
                    end
                end
            end

            local isBossNearby = mob and mob.Name:lower():find("boss") ~= nil

            -- Fire skill remotes
            for _, idx in ipairs(CFG.SkillSet) do
                if not CFG.SkillOnBoss or isBossNearby then
                    if throttle("skill_" .. idx, 0.05) then
                        pcall(function() RequestAbility:FireServer(idx) end)
                        -- Add small random delay between each skill
                        if CFG.AntiDetection then
                            task.wait(math.random(20, 60) / 1000)
                        else
                            task.wait(0.04)
                        end
                    end
                end
            end
        end
    end
end)

