local function getWeaponsFromBackpack()
    local weapons = {}
    pcall(function()
        -- Tools trong Backpack (chưa equip)
        for _, tool in ipairs(player.Backpack:GetChildren()) do
            if tool:IsA("Tool") then
                table.insert(weapons, tool.Name)
            end
        end
        -- Tìm sâu hơn trong Backpack (nested)
        for _, tool in ipairs(player.Backpack:GetDescendants()) do
            if tool:IsA("Tool") then
                table.insert(weapons, tool.Name)
            end
        end
        -- Tool đang cầm trên character
        if character then
            for _, tool in ipairs(character:GetChildren()) do
                if tool:IsA("Tool") then
                    table.insert(weapons, tool.Name)
                end
            end
        end
        -- Fallback: tìm trong StarterPack
        pcall(function()
            for _, tool in ipairs(game:GetService("StarterPack"):GetChildren()) do
                if tool:IsA("Tool") then
                    table.insert(weapons, tool.Name)
                end
            end
        end)
    end)
    -- Remove duplicates
    local seen = {}
    local unique = {}
    for _, name in ipairs(weapons) do
        if not seen[name] then
            seen[name] = true
            table.insert(unique, name)
        end
    end
    return unique
end

