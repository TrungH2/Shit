-- Randomized delay to mimic human behavior
local function safeWait(baseTime, variance)
    variance = variance or 0.3
    local jitter = baseTime * variance * (math.random() * 2 - 1) -- ±variance%
    local final = math.max(0.02, baseTime + jitter)
    task.wait(final)
    return final
end

