local function GetNearestAuraTarget()
    local char = GetCharacter()
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local myPos = root.Position
    local maxRange = CFG.KillAuraRange or 100
    local nearest, lastDist = nil, maxRange
    for _, v in ipairs(PATH.Mobs:GetChildren()) do
        if v:IsA("Model") then
            local hum = v:FindFirstChildOfClass("Humanoid")
            local npcRoot = v:FindFirstChild("HumanoidRootPart") or v:FindFirstChild("Root")
            if hum and hum.Health > 0 and npcRoot then
                local dist = (myPos - npcRoot.Position).Magnitude
                if dist <= lastDist then nearest = v; lastDist = dist end
            end
        end
    end
    return nearest
end

-- ============ COMBO PARSER ============
local function ParseComboPattern(raw)
    local parsed = {}
    if not raw or raw == "" then return parsed end
    for item in string.gmatch(raw:upper():gsub("%s+", ""), "([^,>]+)") do
        table.insert(parsed, item)
    end
    return parsed
end

