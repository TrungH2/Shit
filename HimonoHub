local function GetCurrentWave()
    local waveNum = nil
    pcall(function()
        for _, gui in pairs(Plr.PlayerGui:GetDescendants()) do
            if gui:IsA("TextLabel") and gui.Visible and gui.Text ~= "" then
                local txt = string.lower(gui.Text)
                -- Tìm pattern "wave X" hoặc "floor X" hoặc "tầng X"
                if string.find(txt, "wave") or string.find(txt, "floor") then
                    local num = string.match(txt, "wave%s*(%d+)")
                        or string.match(txt, "floor%s*(%d+)")
                        or string.match(txt, "%d+")
                    if num then
                        waveNum = tonumber(num)
                        return
                    end
                end
            end
        end
    end)
    return waveNum
end

