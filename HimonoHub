-- Helper: tìm mob gần nhất trên map hiện tại (không giới hạn range)
local function findNearestMobOnMap()
    if not rootPart then return nil, nil, nil end
    local best, bestRoot, bestHum, bestDist = nil, nil, nil, math.huge
    
    -- Ưu tiên Mobs folder
    local mobFolders = {}
    for _, name in ipairs({"Mobs", "NPCs", "Enemies", "Monsters"}) do
        local f = workspace:FindFirstChild(name)
        if f then table.insert(mobFolders, f) end
    end
    
    local function scan(container, useDesc)
        local list = useDesc and container:GetDescendants() or container:GetChildren()
        for _, obj in ipairs(list) do
            if obj:IsA("Model") and obj ~= character then
                local hum  = obj:FindFirstChildOfClass("Humanoid")
                local root = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Root")
                if hum and hum.Health > 0 and root then
                    local isPlayer = false
                    for _, p in ipairs(Players:GetPlayers()) do
                        if p.Character == obj then isPlayer = true; break end
                    end
                    if not isPlayer then
                        local d = (rootPart.Position - root.Position).Magnitude
                        if d < bestDist then
                            bestDist = d
                            best = obj
                            bestRoot = root
                            bestHum = hum
                        end
                    end
                end
            end
        end
    end
    
    for _, folder in ipairs(mobFolders) do scan(folder, false) end
    if not best then scan(workspace, true) end
    
    return best, bestRoot, bestHum
end

-- Helper: Lock-on 1 mob → đợi chết → return
-- configKey = cờ toggle để check (VD: "OPFarming" hoặc "AllMapFarming")
-- delay = thời gian giữa mỗi lần tele update
local function lockOnAndKill(mob, mobRoot, mobHum, configKey, delay)
    if not mob or not mobRoot or not mobHum then return end
    local lockStart = tick()
    local MAX_LOCK_TIME = 15 -- 15s timeout phòng mob bất tử
    
    while CFG[configKey] and not _isRespawning and character and humanoid and humanoid.Health > 0 and rootPart do
        -- Mob chết / bị destroy?
        if not mob or not mob.Parent then break end
        if not mobHum or mobHum.Health <= 0 then break end
        if not mobRoot or not mobRoot.Parent then break end
        -- Timeout
        if tick() - lockStart > MAX_LOCK_TIME then break end
        
        -- Teleport tới sau lưng mob
        pcall(function()
            rootPart.CFrame = CFrame.new(mobRoot.Position - mobRoot.CFrame.LookVector * CFG.Distance)
        end)
        
        task.wait(delay)
    end
end

