-- =====================================================
--     ARTIFACT AUTOMATION
-- =====================================================
task.spawn(function()
    while true do
        safeWait(5, 0.3)
        if not (CFG.ArtifactUpgrade or CFG.ArtifactLock or CFG.ArtifactDelete or CFG.ArtifactEquipBest) then continue end
        local inv = CFG.ArtifactInventory or {}
        if not next(inv) then continue end
        local lockQ, delQ, upQ = {}, {}, {}
        for uuid, data in pairs(inv) do
            if CFG.ArtifactUpgrade and ArtifactEquip and (data.Level or 0) < CFG.ArtifactUpgradeLimit then
                table.insert(upQ, {UUID=uuid, Levels=CFG.ArtifactUpgradeLimit})
            end
            if CFG.ArtifactLock and ArtifactLockR and not data.Locked then
                if #(data.Substats or {}) >= CFG.ArtifactLockMinSS then
                    table.insert(lockQ, uuid)
                end
            end
        end
        for _, uuid in ipairs(lockQ) do
            pcall(function() if ArtifactLockR then ArtifactLockR:FireServer(uuid, true) end end)
            task.wait(0.1)
        end
        if CFG.ArtifactDelete and MassDelete then
            for uuid, data in pairs(inv) do
                if not data.Locked then
                    local isLocked = false
                    for _, l in ipairs(lockQ) do if l==uuid then isLocked=true; break end end
                    if not isLocked then table.insert(delQ, uuid) end
                end
            end
            for i=1,#delQ,50 do
                local chunk = {}
                for j=i,math.min(i+49,#delQ) do table.insert(chunk, delQ[j]) end
                pcall(function() MassDelete:FireServer(chunk) end)
                task.wait(0.6)
            end
        end
        if #upQ > 0 and MassUpgrade then
            for i=1,#upQ,50 do
                local chunk = {}
                for j=i,math.min(i+49,#upQ) do table.insert(chunk, upQ[j]) end
                pcall(function() MassUpgrade:FireServer(chunk) end)
                task.wait(0.6)
            end
        end
        if CFG.ArtifactEquipBest and ArtifactEquip then
            local best = {Helmet=nil,Gloves=nil,Body=nil,Boots=nil}
            local bestScores = {Helmet=-1,Gloves=-1,Body=-1,Boots=-1}
            for uuid, data in pairs(inv) do
                if best[data.Category] ~= nil then
                    local score = (data.Level or 0) + (#(data.Substats or {}) * 10)
                    if score > bestScores[data.Category] then
                        bestScores[data.Category] = score
                        best[data.Category] = {UUID=uuid, Equipped=data.Equipped}
                    end
                end
            end
            for _, item in pairs(best) do
                if item and not item.Equipped then
                    pcall(function() ArtifactEquip:FireServer(item.UUID) end)
                    task.wait(0.2)
                end
            end
        end
    end
end)

